{
  "name": "@postplus/cli",
  "version": "0.1.54",
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "type": "module",
  "description": "PostPlus CLI for PostPlus Cloud auth, status, and diagnostics.",
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    "build/account-binding-display.js",
    "build/auth-lifecycle.js",
    "build/auth-login.js",
    "build/auth-session.js",
    "build/auth-validate.js",
    "build/auth.js",
    "build/authed-cloud-request.js",
    "build/authed-cloud-request.d.ts",
    "build/client-compatibility.js",
    "build/command-runner.js",
    "build/doctor.js",
    "build/hosted-account-commands.js",
    "build/hosted-domain-commands.js",
    "build/hosted-domain-commands.d.ts",
    "build/hosted-lib.js",
    "build/hosted-lib.d.ts",
    "build/generated/hosted-execution-manifest.generated.js",
    "build/generated/hosted-field-validation-core.generated.js",
    "build/hosted-field-validation.js",
    "build/hosted-manifest-index.js",
    "build/hosted-manifest-index.d.ts",
    "build/hosted-release.js",
    "build/hosted-request-schemas.js",
    "build/index.js",
    "build/local-dependencies.js",
    "build/local-state.js",
    "build/quote-confirmation.js",
    "build/skill-catalog.js",
    "build/skill-management.js",
    "build/status.js",
    "build/studio.js",
    "build/studio-server.js",
    "build/subscription-status.js",
    "build/update-check.js",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "bin": {
    "postplus": "build/index.js"
  },
  "exports": {
    "./hosted-lib": {
      "types": "./build/hosted-lib.d.ts",
      "default": "./build/hosted-lib.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ./scripts/clean-build.mjs && tsc && node ./scripts/finalize-build.mjs",
    "clean": "rm -rf .turbo node_modules build",
    "release:package": "node ./scripts/package-release.mjs",
    "start": "tsx src/index.ts",
    "test:acceptance": "node ./scripts/acceptance.mjs",
    "test": "tsx --test src/postplus-cli.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PostPlusAI/postplus-cli.git"
  }
}
